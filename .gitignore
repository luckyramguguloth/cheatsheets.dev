# =============================================================================
# cheatsheets.dev — .gitignore
# =============================================================================

# Operating System Files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# Python Virtual Environments & Cache
.venv/
venv/
ENV/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Node.js (Dependencies for Linting tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# Local Build Artifacts
dist/
build/
*.zip
*.pdf

# IDEs & Code Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# Local Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
